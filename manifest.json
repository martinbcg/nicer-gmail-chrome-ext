{
  "manifest_version": 3,
  "name": "Gmail Theme Switcher Pro",
  "version": "1.16",
  "permissions": ["storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
